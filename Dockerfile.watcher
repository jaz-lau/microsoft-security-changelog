# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.watcher
#
# Purpose:
#   Builds the Docker image for the MS Learn watcher that runs on your
#   Synology NAS. This container only runs check_learn_changes.py — it polls
#   MS Learn pages hourly and sends an HTTP trigger to the Mac agent server
#   when new content is detected.
#
# What runs here (NAS):
#   - check_learn_changes.py (lightweight, no GPU needed)
#
# What runs on the Mac:
#   - Ollama + Gemma 4 (needs Apple Silicon GPU)
#   - trigger_server.py (listens for HTTP trigger from this container)
#   - agent_update.py (called by trigger_server.py)
#
# Build:
#   docker build -f Dockerfile.watcher -t ms-learn-watcher .
#
# Placement: repo root
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.12-slim

# Security — run as non-root user
RUN useradd -m -u 1000 watcher
WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir requests beautifulsoup4

# Copy only what the watcher needs
COPY scripts/check_learn_changes.py ./scripts/
COPY data/ ./data/

# Create logs directory
RUN mkdir -p logs && chown -R watcher:watcher /app

USER watcher

CMD ["python3", "scripts/check_learn_changes.py"]
